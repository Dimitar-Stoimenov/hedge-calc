# Normalize all text files to LF in the repository.
# This keeps line endings consistent regardless of each contributor's
# core.autocrlf setting and stops GitHub's "LF -> CRLF" diff warnings.
* text=auto eol=lf

# Explicit text types (belt and suspenders).
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files — never touch these.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
